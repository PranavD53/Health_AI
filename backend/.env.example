# Supabase / Postgres connection (required)
# Use the "Transaction" pooler URL for normal app traffic (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection for migrations / DDL (port 5432) — strongly recommended for Supabase
# Find this under Supabase → Project Settings → Database → Connection string → URI (direct)
DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres

SECRET_KEY=your-secret-key
GROQ_API_KEY=your-groq-api-key
